# ==========================================
# AI Guest Review Analyzer - Backend
# Example Environment Variables
# ==========================================
# Copy this file to .env and replace the placeholder
# values with your own configuration.

# ------------------------------------------
# Application Settings
# ------------------------------------------
HOST=127.0.0.1
PORT=8000
ENVIRONMENT=development

# ------------------------------------------
# Frontend URL (CORS)
# ------------------------------------------
FRONTEND_URL=http://localhost:5173

# ------------------------------------------
# MongoDB Atlas Configuration
# ------------------------------------------
# Replace <username> and <password> with your
# MongoDB Atlas database user credentials.
# Replace the cluster name if yours is different.

MONGO_URI=mongodb+srv://<username>:<password>@ai-guest-review-analyze.zpez3bx.mongodb.net/ai_guest_review_db?retryWrites=true&w=majority&appName=AI-Guest-Review-Analyzer

# ------------------------------------------
# JWT Secret Key
# ------------------------------------------
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key-here

# ------------------------------------------
# Google OAuth Configuration
# ------------------------------------------
# Create credentials at: https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: http://localhost:8000/api/auth/google/callback
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ------------------------------------------
# Google Gemini AI Configuration
# ------------------------------------------
# Get your free API key at: https://aistudio.google.com
# Used by the /api/analyze endpoint for AI-powered sentiment analysis,
# theme detection, and professional response generation.
# If left empty, the endpoint falls back to keyword-based analysis.
GEMINI_API_KEY=your-gemini-api-key-here

# ==========================================
# End of Example Configuration
# ==========================================