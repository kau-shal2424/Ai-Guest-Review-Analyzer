# ==========================================
# AI Guest Review Analyzer - Backend
# Example Environment Variables
# ==========================================
# Copy this file to .env and replace the values
# with your own configuration before running
# the backend.

# ------------------------------------------
# Application Settings
# ------------------------------------------
HOST=127.0.0.1
PORT=8000
ENVIRONMENT=development

# ------------------------------------------
# CORS
# ------------------------------------------
FRONTEND_URL=http://localhost:5173

# ------------------------------------------
# Future Database Configuration (Week 5)
# ------------------------------------------
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/guest_reviews

# ------------------------------------------
# Future AI Configuration (Optional)
# ------------------------------------------
# OPENAI_API_KEY=your_openai_api_key

# ==========================================
# End of Example Configuration
# ==========================================