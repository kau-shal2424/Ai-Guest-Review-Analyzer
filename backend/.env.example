# ==========================================
# AI Guest Review Analyzer - Backend
# Example Environment Variables
# ==========================================
# Copy this file to .env and replace the placeholder
# values with your own configuration.

# ------------------------------------------
# Application Settings
# ------------------------------------------
HOST=127.0.0.1
PORT=8000
ENVIRONMENT=development

# ------------------------------------------
# Frontend URL (CORS)
# ------------------------------------------
FRONTEND_URL=http://localhost:5173

# ------------------------------------------
# MongoDB Atlas Configuration
# ------------------------------------------
# Replace <username> and <password> with your
# MongoDB Atlas database user credentials.
# Replace the cluster name if yours is different.

MONGO_URI=mongodb+srv://<username>:<password>@ai-guest-review-analyze.zpez3bx.mongodb.net/ai_guest_review_db?retryWrites=true&w=majority&appName=AI-Guest-Review-Analyzer

# ==========================================
# End of Example Configuration
# ==========================================